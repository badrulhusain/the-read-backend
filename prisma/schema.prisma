generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  AUTHOR
  EDITOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum BlogStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum ReviewDecision {
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum CommentStatus {
  VISIBLE
  HIDDEN
  DELETED
  PENDING
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)

  avatarUrl      String?
  avatarPublicId String?

  blogs         Blog[]        @relation("BlogAuthor")
  assignedBlogs Blog[]        @relation("AssignedEditor")
  reviews       BlogReview[]
  versions      BlogVersion[]
  auditLogs     AuditLog[]
  comments      Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
}

model Blog {
  id         String  @id @default(uuid())
  title      String
  slug       String  @unique
  excerpt    String?
  content    String
  coverImage         String?
  coverImagePublicId String?

  status BlogStatus @default(DRAFT)

  authorId String
  author   User   @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  assignedEditorId String?
  assignedEditor   User?   @relation("AssignedEditor", fields: [assignedEditorId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  tags BlogTag[]

  wordCount      Int?
  readingTime    Int?
  seoTitle       String?
  seoDescription String?

  publishedAt DateTime?

  reviews  BlogReview[]
  versions BlogVersion[]
  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([assignedEditorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([createdAt])
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  isActive    Boolean @default(true)
  blogs       Blog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

model Tag {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  isActive Boolean   @default(true)
  blogs    BlogTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

model BlogTag {
  blogId String
  tagId  String
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([blogId, tagId])
  @@index([tagId])
}

model BlogReview {
  id String @id @default(uuid())

  blogId String
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  editorId String
  editor   User   @relation(fields: [editorId], references: [id], onDelete: Restrict)

  decision        ReviewDecision
  comment         String?
  plagiarismScore Int?
  plagiarismNote  String?
  checklist       Json?

  createdAt DateTime @default(now())

  @@index([blogId])
  @@index([editorId])
  @@index([decision])
}

model BlogVersion {
  id String @id @default(uuid())

  blogId String
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  title         String
  content       String
  versionNumber Int

  editedById String
  editedBy   User   @relation(fields: [editedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([blogId])
  @@index([editedById])
}

model Comment {
  id       String        @id @default(uuid())
  blogId   String
  blog     Blog          @relation(fields: [blogId], references: [id], onDelete: Cascade)
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentId String?
  content  String
  status   CommentStatus @default(VISIBLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blogId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([parentId])
}

model AuditLog {
  id String @id @default(uuid())

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}
