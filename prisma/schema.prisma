generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AUTHOR
  EDITOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum BlogStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum ReviewDecision {
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)

  blogs         Blog[]        @relation("BlogAuthor")
  assignedBlogs Blog[]        @relation("AssignedEditor")
  reviews       BlogReview[]
  versions      BlogVersion[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
}

model Blog {
  id         String  @id @default(uuid())
  title      String
  slug       String  @unique
  excerpt    String?
  content    String
  coverImage String?

  status BlogStatus @default(DRAFT)

  authorId String
  author   User   @relation("BlogAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  assignedEditorId String?
  assignedEditor   User?   @relation("AssignedEditor", fields: [assignedEditorId], references: [id], onDelete: SetNull)

  publishedAt DateTime?

  reviews  BlogReview[]
  versions BlogVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([assignedEditorId])
  @@index([publishedAt])
  @@index([createdAt])
}

model BlogReview {
  id String @id @default(uuid())

  blogId String
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  editorId String
  editor   User   @relation(fields: [editorId], references: [id], onDelete: Restrict)

  decision ReviewDecision
  comment  String?

  createdAt DateTime @default(now())

  @@index([blogId])
  @@index([editorId])
  @@index([decision])
}

model BlogVersion {
  id String @id @default(uuid())

  blogId String
  blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

  title         String
  content       String
  versionNumber Int

  editedById String
  editedBy   User   @relation(fields: [editedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([blogId])
  @@index([editedById])
}

model AuditLog {
  id String @id @default(uuid())

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}
